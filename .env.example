# Digital Pulse - Backend Environment Variables

# =====================================
# DATABASE CONFIGURATION (Supabase)
# =====================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# =====================================
# REDDIT API (Optional)
# Get credentials at: https://www.reddit.com/prefs/apps
# =====================================
REDDIT_CLIENT_ID=your-client-id
REDDIT_CLIENT_SECRET=your-client-secret
REDDIT_USER_AGENT=digital-pulse-bot/1.0

# =====================================
# NEWS API (Optional)
# Get API key at: https://newsapi.org/
# =====================================
NEWSAPI_KEY=your-newsapi-key-here

# =====================================
# GOOGLE NEWS RSS (No API key needed)
# =====================================
# No configuration required

# =====================================
# SERVER CONFIGURATION
# =====================================
# Environment: development, production
ENVIRONMENT=development

# API host and port
HOST=0.0.0.0
PORT=8000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =====================================
# FEATURE FLAGS
# =====================================
# Enable/disable scrapers
ENABLE_REDDIT_SCRAPER=true
ENABLE_NEWSAPI_SCRAPER=true
ENABLE_GOOGLE_NEWS_SCRAPER=true

# Scraping intervals (seconds)
REDDIT_SCRAPE_INTERVAL=300
NEWSAPI_SCRAPE_INTERVAL=600
GOOGLE_NEWS_SCRAPE_INTERVAL=600

# Clustering interval (seconds)
CLUSTERING_INTERVAL=300

# =====================================
# ML MODEL CONFIGURATION
# =====================================
# BERTopic parameters
MIN_TOPIC_SIZE=5
MAX_TOPICS=15

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# =====================================
# CACHING
# =====================================
# Cache TTL in seconds
CACHE_TTL=30

# =====================================
# LOGGING
# =====================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# =====================================
# SECURITY (Production)
# =====================================
# Secret key for JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here

# API rate limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
