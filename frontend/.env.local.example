# Digital Pulse - Frontend Environment Variables

# =====================================
# API CONFIGURATION
# =====================================
# Backend API URL
# Development: http://localhost:8000
# Production: https://your-api.render.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# =====================================
# FEATURE FLAGS
# =====================================
# Enable debug logs in console
NEXT_PUBLIC_DEBUG_MODE=true

# Enable demo mode (disables auto-refresh)
NEXT_PUBLIC_DEMO_MODE=false

# =====================================
# ANALYTICS (Optional)
# =====================================
# Google Analytics ID
NEXT_PUBLIC_GA_ID=

# =====================================
# PERFORMANCE TUNING
# =====================================
# Data fetch limits
NEXT_PUBLIC_MAX_NARRATIVES=20
NEXT_PUBLIC_MAX_CLUSTERS=15
NEXT_PUBLIC_MAX_EMERGING=10
NEXT_PUBLIC_MAX_FORECASTS=8

# Cache TTL (milliseconds)
NEXT_PUBLIC_CACHE_TTL=30000

# Auto-refresh interval (milliseconds, 0 = disabled)
NEXT_PUBLIC_REFRESH_INTERVAL=0
